    "@orpc/server": "^1.9.0",
    "@storybook-vrt-sample/api-contract": "workspace:*",
    "drizzle-orm": "^0.45.1",
    "hono": "^4.8.3"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20250313.0",
    "@types/bun": "^1.3.10",
    "drizzle-kit": "^0.31.9",
    "typescript": "^5.9.3",
    "wrangler": "^4.14.0"
  }
}
