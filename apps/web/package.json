{
  "name": "web",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "🏗️": "========== Dev & Build ==========",
    "dev": "dotenvx run -- next dev --turbopack",
    "build": "dotenvx run -- next build",
    "start": "dotenvx run -- next start",
    "🎨": "========== Code Quality ==========",
    "typecheck": "tsgo --noEmit",
    "🧪": "========== Testing ==========",
    "test": "bun test app/",
    "e2e:playwright": "bunx playwright test",
    "e2e:reg": "mkdir -p .reg/report .reg/expected && reg-cli .reg/actual .reg/expected .reg/diff -R .reg/report/index.html -J .reg/out.json -M 0.01",
    "e2e:reg:local": "rm -rf .reg/expected && mkdir -p .reg/expected && (git -C $(git rev-parse --show-toplevel) archive $(git merge-base HEAD main):apps/web/e2e/screenshots/ 2>/dev/null | tar -x -C .reg/expected/ || true) && bun run e2e:playwright && bun run e2e:reg",
    "📦": "========== Dependency Management ==========",
    "deps:update": "bun update --latest"
  },
  "dependencies": {
    "@sentry/nextjs": "^10.43.0",
    "@storybook-vrt-sample/ui": "workspace:*",
    "next": "^16.1.6",
    "react": "^19.2.4",
    "react-dom": "^19.2.4"
  },
  "devDependencies": {
    "@dotenvx/dotenvx": "^1.54.1",
    "@playwright/test": "^1.58.2",
    "@tailwindcss/postcss": "^4.2.1",
    "@types/node": "^25.3.5",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "postcss": "^8.5.8",
    "reg-cli": "^0.18.14",
    "tailwindcss": "^4.2.1",
    "typescript": "^5.9.3"
  }
}
