{
  "name": "@storybook-vrt-sample/ui",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "imports": {
    "#*": [
      "./*",
      "./*.ts",
      "./*.tsx"
    ]
  },
  "exports": {
    ".": "./src/index.ts",
    "./styles.css": "./src/styles.css"
  },
  "scripts": {
    "📖": "========== Storybook ==========",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build",
    "🎨": "========== Code Quality ==========",
    "typecheck": "tsgo --noEmit",
    "🧪": "========== Testing ==========",
    "test": "bun test src/",
    "storybook:test": "vitest run --project=storybook-test",
    "storybook:snapshot": "vitest run --project=storybook-snapshot",
    "storybook:reg": "mkdir -p .reg/report .reg/expected && reg-cli .reg/actual .reg/expected .reg/diff -R .reg/report/index.html -J .reg/out.json -M 0.01",
    "storybook:reg:local": "rm -rf .reg/expected && mkdir -p .reg/expected && (git -C $(git rev-parse --show-toplevel) archive $(git merge-base HEAD main):packages/ui/vrt/screenshots/ 2>/dev/null | tar -x -C .reg/expected/ || true) && bun run storybook:snapshot && bun run storybook:reg",
    "📦": "========== Dependency Management ==========",
    "deps:update": "bun update --latest"
  },
  "dependencies": {
    "@heroicons/react": "^2.2.0",
    "@storybook-vrt-sample/api-contract": "workspace:*",
    "clsx": "^2.1.1",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "tailwind-merge": "^3.5.0"
  },
  "devDependencies": {
    "@storybook/addon-a11y": "^10.2.16",
    "@storybook/addon-docs": "^10.2.16",
    "@storybook/addon-mcp": "0.4.2",
    "@storybook/addon-vitest": "^10.2.16",
    "@storybook/nextjs-vite": "^10.2.16",
    "@storybook/react": "^10.2.16",
    "@tailwindcss/vite": "^4.2.1",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitest/browser-playwright": "^4.0.18",
    "@vitest/coverage-v8": "^4.0.18",
    "msw": "^2.12.14",
    "msw-storybook-addon": "^2.0.6",
    "next": "^16.1.6",
    "playwright": "^1.58.2",
    "reg-cli": "^0.18.14",
    "storybook": "^10.2.16",
    "storybook-addon-pseudo-states": "^10.2.16",
    "storybook-addon-vis": "^3.1.2",
    "tailwindcss": "^4.2.1",
    "typescript": "^6.0.0",
    "vitest": "^4.0.18"
  },
  "msw": {
    "workerDirectory": [
      "public"
    ]
  }
}
