# 依存パッケージ
node_modules/

# ビルド出力
# Next.js ビルド出力
.next/
# Next.js 静的エクスポート出力
out/
# TypeScript コンパイル出力
dist/
# TypeScript インクリメンタルコンパイルキャッシュ
*.tsbuildinfo
# Storybook ビルド出力
storybook-static/
# Storybook ビルドログ（Chromatic ローカル実行時に生成）
build-storybook.log

# Playwright テスト結果
# テスト実行時の差分画像・スクリーンショット
test-results/
# HTML レポート
playwright-report/
# CI 用レポート
blob-report/
# Vitest カバレッジ出力
coverage/

# 環境変数（機密情報を含むためコミットしない）
.env
!infra/**/.env
!apps/web/.env
!mcp/.env
.env.local
.env.*.local
.env.sentry-build-plugin

# Next.js 自動生成ファイル（next dev / next build のたびに再生成される）
# https://nextjs.org/docs/app/api-reference/config/typescript
next-env.d.ts

# storybook-addon-vis（テスト結果・差分画像はコミットしない）
**/__vis__/__diff_output__
**/__vis__/**/__diffs__
**/__vis__/**/__results__
**/__vis__/local

# reg-cli
.reg/

# Playwright MCP（ブラウザ操作ツールの一時ファイル）
.playwright-mcp/

# OS 生成ファイル
.DS_Store
Thumbs.db

# OXC キャッシュ
.oxc_cache/

# IDE 設定
.vscode/*
!.vscode/settings.json
!.vscode/extensions.json
.idea/
*.swp
*.swo

# Wrangler（Cloudflare Workers ローカル開発の一時ファイル）
.wrangler/

# Terraform
**/.terraform/
*.tfstate
*.tfstate.backup
*.tfplan

# dotenvx（復号キーはコミットしない）
.env.keys

# Claude Code（ローカル設定はユーザー固有のため共有しない）
.claude/settings.local.json
